datasource db {
  provider = "postgresql"
}

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

enum VoteType {
  UP
  DOWN
}

enum TargetType {
  QUESTION
  ANSWER
}

model User {
  id               String            @id @default(uuid())
  username         String            @unique
  email            String            @unique
  password         String
  created_at       DateTime          @default(now())
  questions        Question[]
  answers          Answer[]
  questionVotes    QuestionVote[]
  answerVotes      AnswerVote[]
  questionComments QuestionComment[]
  answerComments   AnswerComment[]
}

model Question {
  id               String            @id @default(uuid())
  title            String
  description      String
  created_at       DateTime          @default(now())
  answers          Answer[]
  tags             QuestionTag[]
  questionVotes    QuestionVote[]
  questionComments QuestionComment[]

  userId String
  user   User   @relation(fields: [userId], references: [id])
}

model Answer {
  id          String       @id @default(uuid())
  content     String
  isAccepted  Boolean      @default(false)
  created_at  DateTime     @default(now())
  answerVotes AnswerVote[]

  questionId     String
  question       Question        @relation(fields: [questionId], references: [id])
  userId         String
  user           User            @relation(fields: [userId], references: [id])
  answerComments AnswerComment[]
}

model Tag {
  id        String        @id @default(uuid())
  name      String        @unique
  questions QuestionTag[]
}

model QuestionTag {
  id String @id @default(uuid())

  questionId String
  question   Question @relation(fields: [questionId], references: [id])
  tagId      String
  tag        Tag      @relation(fields: [tagId], references: [id])
}

model QuestionVote {
  id         String   @id @default(uuid())
  voteType   VoteType
  created_at DateTime @default(now())

  userId     String
  user       User     @relation(fields: [userId], references: [id])
  questionId String
  question   Question @relation(fields: [questionId], references: [id])

  @@unique([userId, questionId])
}

model AnswerVote {
  id         String   @id @default(uuid())
  voteType   VoteType
  created_at DateTime @default(now())

  userId   String
  user     User   @relation(fields: [userId], references: [id])
  answerId String
  answer   Answer @relation(fields: [answerId], references: [id])

  @@unique([userId, answerId])
}

model QuestionComment {
  id         String   @id @default(uuid())
  content    String
  created_at DateTime @default(now())

  userId     String
  user       User     @relation(fields: [userId], references: [id])
  questionId String
  question   Question @relation(fields: [questionId], references: [id])
}

model AnswerComment {
  id         String   @id @default(uuid())
  content    String
  created_at DateTime @default(now())

  userId   String
  user     User   @relation(fields: [userId], references: [id])
  answerId String
  answer   Answer @relation(fields: [answerId], references: [id])
}
